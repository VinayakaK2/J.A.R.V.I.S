# ── Secrets & credentials — NEVER commit these ────────────────────────────────
.env
*.pem
*.key
*.p12
*.pfx

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Database files (SQLite — regenerated at startup) ──────────────────────────
*.db
*.sqlite
*.sqlite3

# ── JARVIS workspace (runtime-generated files) ────────────────────────────────
jarvis/workspace/
workspace/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE / OS ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Node (frontend) ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/dist/
frontend/build/

# ── Pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
