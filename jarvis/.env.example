# ──────────────────────────────────────────────────────────
# JARVIS v7 — Environment Variables Template
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────

# ── LLM / AI ──────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs voice ID to use for TTS synthesis.
# Default "Rachel" (21m00Tcm4TlvDq8ikWAM) — calm, works well for Hinglish.
# Browse voices at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./jarvis.db

# ── Application ────────────────────────────────────────────
LOG_LEVEL=INFO
WORKSPACE_DIR=./workspace

# Public-facing URL of this JARVIS server (no trailing slash).
# Used to build audio file URLs that Twilio can fetch during voice calls.
# For local dev use ngrok: https://abc123.ngrok-free.app
BASE_URL=https://your-public-domain.ngrok-free.app

# ── Owner Identity ─────────────────────────────────────────
# These values are used by auth/identity.py to grant full owner-level access.
# Phone: E.164 format including country code (e.g. +919876543210)
OWNER_PHONE=+91XXXXXXXXXX
# Telegram user ID — send /start to @userinfobot to get your numeric ID
OWNER_TELEGRAM_ID=123456789
OWNER_NAME=Vinayaka

# ── Twilio ─────────────────────────────────────────────────
# WhatsApp + Voice credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# From number for WhatsApp (Twilio Sandbox or approved sender)
# Sandbox default: whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Twilio phone number in E.164 format for inbound voice calls
# (buy a number at https://console.twilio.com/us1/develop/phone-numbers)
TWILIO_VOICE_NUMBER=+1XXXXXXXXXX

# ── Telegram ───────────────────────────────────────────────
# Create a bot via @BotFather — copy the token it gives you
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Feature Flags (V6 / V7 Architecture) ──────────────────
USE_HIERARCHICAL_PLANNER=true
USE_CRITIC_AGENT=true
USE_SEMANTIC_PERCEPTION=true
USE_SIMULATION=false

# ── Background Agent ───────────────────────────────────────
BACKGROUND_POLL_INTERVAL=10
